# Copy this file to .env and adjust values for the target machine.
# The defaults are intentionally safe: real CAN writes stay disabled.

EXCAVATOR_ENV_NAME=excavator-real-stack

# Orbbec camera ROS2 workspace (from机 OrbbecSDK_ROS2).
EXCAVATOR_ORBBEC_WS=${HOME}/orbbec_ws
EXCAVATOR_ORBBEC_SRC=${HOME}/orbbec_ws/src/OrbbecSDK_ROS2
# excavator_ros2_bridge colcon 工作空间（可与 orbbec_ws 相同或单独 ros2_ws）
EXCAVATOR_ROS_WS=${HOME}/ros2_ws

# Recording deployment: host=HDF5 on operator PC, slave=HDF5 on vehicle PC.
# EXCAVATOR_DATA_SIDE=host
# EXCAVATOR_HOST_DATASET_DIR=data/real_teleop_v1
# EXCAVATOR_SLAVE_DATASET_DIR=/data/real_teleop_v1

# JSON/TCP bridge endpoint used by testbed bridge_tcp (host mode -> vehicle gateway).
EXCAVATOR_BRIDGE_HOST=127.0.0.1
EXCAVATOR_BRIDGE_PORT=8765

# Target-machine CAN interface names. Keep simulation enabled until bring-up.
EXCAVATOR_CAN_IF=can0
EXCAVATOR_IMU_IF=can1
EXCAVATOR_CAN_SIMULATION=true
EXCAVATOR_IMU_SIMULATION=true
EXCAVATOR_CAN_BUS_ENABLED=false
EXCAVATOR_CREATE_MAPPING=true

# Safety and smoke-test timing.
EXCAVATOR_HEARTBEAT_TIMEOUT_MS=500
EXCAVATOR_READ_TIMEOUT_MS=100

# Placeholder image returned by the C++ bridge until the real camera path exists.
EXCAVATOR_IMAGE_WIDTH=160
EXCAVATOR_IMAGE_HEIGHT=120

# Smoke recorder settings.
EXCAVATOR_SMOKE_NUM_EPISODES=1
EXCAVATOR_SMOKE_MAX_STEPS=3
# Leave empty to use /tmp/excavator-real-stack-smoke-<timestamp>.
EXCAVATOR_SMOKE_OUTPUT_DIR=

# Build behavior.
EXCAVATOR_SMOKE_BUILD=1
# Leave empty to use the active conda prefix or the configured conda env prefix.
EXCAVATOR_CMAKE_PREFIX_PATH=

# This must stay 0 for normal smoke tests. Set to 1 only during supervised
# hardware bring-up after e-stop, manual override, and one-axis limits are ready.
EXCAVATOR_ALLOW_REAL_CAN_SMOKE=0

# Target-machine read-only CAN probe defaults.
EXCAVATOR_CAN_PROBE_DURATION_S=10
EXCAVATOR_CAN_PROBE_IDS="18F021F6 18F022F6 18F023F6"
EXCAVATOR_CAN_PROBE_OUTPUT_DIR=artifacts/can_probe

# Supervised one-axis bring-up defaults. These values are intentionally small.
EXCAVATOR_ONE_AXIS=swing
EXCAVATOR_ONE_AXIS_DIRECTION=positive
EXCAVATOR_ONE_AXIS_AMPLITUDE=0.03
EXCAVATOR_ONE_AXIS_DURATION_S=0.5
